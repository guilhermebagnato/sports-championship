# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_USER=sports_user
POSTGRES_PASSWORD=sports_pass
POSTGRES_DB=sports_championship

# ============================================
# BACKEND CONFIGURATION
# ============================================
DATABASE_URL=postgresql://sports_user:sports_pass@postgres:5432/sports_championship

# JWT & Security
SECRET_KEY=your-super-secret-key-change-this-in-production-with-something-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
DEBUG=False
CORS_ORIGINS=http://localhost:5173,http://localhost,http://localhost:80

# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_API_URL=http://localhost:8000/api

# ============================================
# PGADMIN CONFIGURATION (opcional)
# ============================================
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
